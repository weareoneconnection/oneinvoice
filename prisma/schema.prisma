generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id                   String              @id @default(cuid())
  name                 String
  tin                  String              @default("")
  myInvoisClientId     String              @default("")
  myInvoisClientSecret String              @default("")
  myInvoisMode         String              @default("sandbox")
  // Billing
  plan                 String              @default("free")   // free | starter | pro
  stripeCustomerId     String?             @unique
  stripeSubscriptionId String?             @unique
  stripePriceId        String?
  subscriptionStatus   String              @default("active") // active | past_due | canceled | trialing
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime            @default(now())
  users                User[]
  receipts             Receipt[]
  customerRequests     CustomerRequest[]
  consolidatedBatches  ConsolidatedBatch[]
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String
  name           String?
  restaurantId   String?
  createdAt      DateTime   @default(now())
  restaurant     Restaurant? @relation(fields: [restaurantId], references: [id])
  accounts       Account[]
  sessions       Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Receipt {
  id                String     @id @default(cuid())
  restaurantId      String
  receiptNo         String
  outlet            String
  channel           String     @default("dine_in")
  date              DateTime
  subtotal          Float      @default(0)
  serviceCharge     Float      @default(0)
  sst               Float      @default(0)
  discount          Float      @default(0)
  rounding          Float      @default(0)
  total             Float
  status            String     @default("normal")
  customerRequestId String?
  items             String     @default("[]")
  createdAt         DateTime   @default(now())
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, receiptNo])
}

model CustomerRequest {
  id                 String     @id @default(cuid())
  restaurantId       String
  receiptId          String
  receiptNo          String
  customerType       String     @default("individual")
  name               String
  tin                String
  idType             String     @default("NRIC")
  idNumber           String
  email              String
  phone              String?
  address            String
  status             String     @default("pending")
  myInvoisDocumentId String?
  error              String?
  createdAt          DateTime   @default(now())
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id])
}

model ConsolidatedBatch {
  id                   String     @id @default(cuid())
  restaurantId         String
  month                String
  outlet               String
  receiptCount         Int        @default(0)
  amount               Float      @default(0)
  sst                  Float      @default(0)
  status               String     @default("draft")
  receiptIds           String     @default("[]")
  myInvoisSubmissionId String?
  createdAt            DateTime   @default(now())
  restaurant           Restaurant @relation(fields: [restaurantId], references: [id])
}
