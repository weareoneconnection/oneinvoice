# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-32-chars-minimum

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://...
DATABASE_URL_UNPOOLED=postgresql://...

# AI
ANTHROPIC_API_KEY=sk-ant-...

# MyInvois (per-restaurant, set in /settings/restaurant)
# MYINVOIS_MODE and credentials are stored per-restaurant in the database

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=OneInvoice AI <noreply@oneai.network>

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...   # RM 99/month price ID from Stripe dashboard
STRIPE_PRICE_PRO=price_...       # RM 299/month price ID from Stripe dashboard
